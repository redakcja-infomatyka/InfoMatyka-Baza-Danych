        let activeSurvey = 'przed';

        function setSurvey(surveyType) {
            activeSurvey = surveyType;

            document.getElementById('btn-przed').classList.toggle('active', surveyType === 'przed');
            document.getElementById('btn-po').classList.toggle('active', surveyType === 'po');

            const data = SURVEYS[surveyType];

            document.getElementById('download-pdf-btn').href = "https://www.infomatyka.pl/p/generator-testow-sprawdzianow-wypelnij.html";
            document.getElementById('download-docx-btn').href = "https://www.infomatyka.pl/p/generator-testow-sprawdzianow-wypelnij.html";

            renderPaperPreview(data);
        }

        function parseQuestionText(text) {
            let mainText = text;
            let tagText = "";
            const tagMatch = text.match(/\[(.*?)\]/);

            if (tagMatch) {
                mainText = text.replace(/\[(.*?)\]/, "").trim();
                if (mainText.endsWith(':')) {
                    mainText = mainText.slice(0, -1).trim();
                }
                tagText = tagMatch[1];
            }
            return { mainText, tagText };
        }

        function renderPaperPreview(data) {
            const container = document.getElementById('survey-paper-preview');
            let html = `
                <div class="print-header">
                    <h2>${data.title}</h2>
                    <div style="font-size: 14.5px; text-transform: none; margin-top: 5px; font-weight: normal; font-style: italic;">
                        ${data.subtitle}
                    </div>
                </div>
                <div class="print-intro">
                    ${data.intro}
                </div>
                <div class="print-meta-instruction">
                    ${data.instruction}
                </div>
                <div class="question-list">
            `;

            data.sections.forEach((section) => {
                html += `
                    <div class="section-container" style="margin-top: 25px; margin-bottom: 15px; border-bottom: 1px solid #000; padding-bottom: 5px; page-break-after: avoid;">
                        <h3 style="font-family: 'Times New Roman', Times, serif; font-size: 16px; text-transform: uppercase; margin: 0; font-weight: bold;">
                            ${section.title}
                        </h3>
                    </div>
                `;

                section.questions.forEach((q) => {
                    const parsed = parseQuestionText(q.text);

                    html += `
                        <div class="question-item" style="margin-bottom: 20px; page-break-inside: avoid;">
                            <div class="question-text">
                                <span class="question-main-text">${parsed.mainText}:</span>
                                ${parsed.tagText ? `<span class="question-tag">${parsed.tagText}</span>` : ''}
                            </div>
                    `;

                    if (q.type === 'choice' || q.type === 'multiselect') {
                        html += `<div class="options-container" style="margin-left: 15px;">`;
                        q.options.forEach(opt => {
                            html += `
                                <div class="option-row" style="display: flex; align-items: center; margin-bottom: 6px; font-size: 14.5px;">
                                    <div class="checkbox-square">&nbsp;</div>
                                    <span>${opt}</span>
                                </div>
                            `;
                        });
                        html += `</div>`;
                    } else if (q.type === 'scale') {
                        html += `
                            <div style="margin-left: 15px; margin-top: 8px; margin-bottom: 8px;">
                                <table class="scale-table">
                                    <tr>
                                        <td style="text-align: left; font-weight: bold; font-size: 12px; width: 20%; border: 1px solid #000; padding: 6px;">${q.labelMin}</td>
                                        <td style="border: 1px solid #000; padding: 6px; width: 12%;"><div style="display: flex; flex-direction: column; align-items: center; gap: 4px;"><div class="checkbox-square" style="margin: 0;">&nbsp;</div><span>1</span></div></td>
                                        <td style="border: 1px solid #000; padding: 6px; width: 12%;"><div style="display: flex; flex-direction: column; align-items: center; gap: 4px;"><div class="checkbox-square" style="margin: 0;">&nbsp;</div><span>2</span></div></td>
                                        <td style="border: 1px solid #000; padding: 6px; width: 12%;"><div style="display: flex; flex-direction: column; align-items: center; gap: 4px;"><div class="checkbox-square" style="margin: 0;">&nbsp;</div><span>3</span></div></td>
                                        <td style="border: 1px solid #000; padding: 6px; width: 12%;"><div style="display: flex; flex-direction: column; align-items: center; gap: 4px;"><div class="checkbox-square" style="margin: 0;">&nbsp;</div><span>4</span></div></td>
                                        <td style="border: 1px solid #000; padding: 6px; width: 12%;"><div style="display: flex; flex-direction: column; align-items: center; gap: 4px;"><div class="checkbox-square" style="margin: 0;">&nbsp;</div><span>5</span></div></td>
                                        <td style="text-align: right; font-weight: bold; font-size: 12px; width: 20%; border: 1px solid #000; padding: 6px;">${q.labelMax}</td>
                                    </tr>
                                </table>
                            </div>
                        `;
                    } else if (q.type === 'text') {
                        html += `<div class="dotted-area" style="margin-top: 5px; margin-left: 15px;">`;
                        const linesCount = q.lines || 3;
                        for (let i = 0; i < linesCount; i++) {
                            html += `<div class="dotted-line"></div>`;
                        }
                        html += `</div>`;
                    }

                    html += `</div>`;
                });
            });

            html += `
                </div>
                <div class="print-footer">
                    <div class="thanks-message">Bardzo dziękuję za wypełnienie ankiety.</div>
                    <div class="author-signature">
                        Mateusz Giętowski<br>
                        student 2 roku studiów magisterskich kierunku Nauczania Matematyki I Informatyki<br>
                        na Uniwersytecie im. Adama Mickiewicza w Poznaniu
                    </div>
                </div>
            `;

            container.innerHTML = html;
        }

        // Nowy zoptymalizowany mechanizm drukowania z wymuszeniem renderowania stylów graficznych
        function printSurvey() {
            const previewContent = document.getElementById('survey-paper-preview').innerHTML;
            const printWindow = window.open('', '_blank', 'width=1024,height=800');

            printWindow.document.write(`
                <!DOCTYPE html>
                <html lang="pl" class="notranslate">
                <head>
                    <meta charset="UTF-8">
                    <meta name="google" content="notranslate" />
                    <title>Drukuj Ankietę - Portal InfoMatyka</title>
                    <style>
                        body {
                            font-family: 'Times New Roman', Times, serif;
                            color: #000;
                            background: #fff;
                            margin: 20mm;
                            line-height: 1.5;
                            -webkit-print-color-adjust: exact !important;
                            print-color-adjust: exact !important;
                        }
                        .print-header {
                            text-align: center;
                            margin-bottom: 30px;
                            border-bottom: 2px double #000;
                            padding-bottom: 15px;
                        }
                        .print-header h2 {
                            font-size: 20px;
                            font-weight: bold;
                            margin: 0 0 10px 0;
                            text-transform: uppercase;
                        }
                        .print-intro {
                            font-size: 14.5px;
                            text-align: justify;
                            margin-bottom: 25px;
                        }
                        .print-meta-instruction {
                            font-size: 14px;
                            font-style: italic;
                            margin-bottom: 25px;
                            border-left: 3px solid #000;
                            padding-left: 12px;
                        }
                        .section-container {
                            margin-top: 25px;
                            margin-bottom: 15px;
                            border-bottom: 1px solid #000;
                            padding-bottom: 5px;
                            page-break-after: avoid;
                        }
                        .section-container h3 {
                            font-size: 15px;
                            text-transform: uppercase;
                            margin: 0;
                            font-weight: bold;
                        }
                        .question-item {
                            margin-bottom: 22px;
                            page-break-inside: avoid;
                        }
                        .question-text {
                            display: flex;
                            justify-content: space-between;
                            align-items: flex-start;
                            gap: 15px;
                            font-size: 14.5px;
                            font-weight: bold;
                            margin-bottom: 12px;
                            line-height: 1.4;
                        }
                        .question-main-text {
                            max-width: 80%;
                        }
                        .question-tag {
                            font-size: 11.5px;
                            font-weight: normal;
                            font-style: italic;
                            color: #333;
                            display: inline-block;
                            white-space: nowrap;
                            margin-left: 8px;
                            border: 1px dashed #555 !important;
                            padding: 1px 5px;
                            border-radius: 3px;
                            flex-shrink: 0;
                            margin-left: auto;
                            -webkit-print-color-adjust: exact !important;
                            print-color-adjust: exact !important;
                        }
                        .options-container {
                            margin-left: 15px;
                        }
                        .option-row {
                            display: flex;
                            align-items: center;
                            margin-bottom: 8px;
                            font-size: 14px;
                        }
                        .checkbox-square {
                            width: 14px;
                            height: 14px;
                            border: 1.5px solid #000000 !important;
                            background-color: #ffffff !important;
                            margin-right: 10px;
                            display: inline-block;
                            vertical-align: middle;
                            flex-shrink: 0;
                            -webkit-print-color-adjust: exact !important;
                            print-color-adjust: exact !important;
                        }
                        .dotted-line {
                            border-bottom: 1px dashed #000000 !important;
                            margin-top: 15px;
                            height: 20px;
                            display: block;
                            -webkit-print-color-adjust: exact !important;
                            print-color-adjust: exact !important;
                        }
                        .dotted-area {
                            margin-top: 8px;
                            margin-left: 15px;
                        }
                        .scale-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin-top: 8px;
                            margin-bottom: 8px;
                        }
                        .scale-table th, .scale-table td {
                            border: 1px solid #000000 !important;
                            padding: 8px;
                            text-align: center;
                            font-size: 13px;
                            -webkit-print-color-adjust: exact !important;
                            print-color-adjust: exact !important;
                        }
                        .scale-table th {
                            background-color: #f2f2f2 !important;
                        }
                        .print-footer {
                            margin-top: 60px;
                            border-top: 2px solid #000;
                            padding-top: 20px;
                            font-size: 16px;
                            line-height: 1.5;
                            page-break-inside: avoid;
                            display: flow-root;
                            padding-bottom: 60px;
                        }
                        .print-footer .thanks-message {
                            font-weight: bold;
                            text-align: justify;
                            margin-bottom: 15px;
                        }
                        .print-footer .author-signature {
                            float: right;
                            text-align: right;
                            margin-top: 15px;
                            font-style: italic;
                            font-size: 15px;
                            font-weight: bold;
                            line-height: 1.4;
                        }
                        @media print {
                            body { margin: 15mm; }
                            .checkbox-square {
                                border: 1.5px solid #000000 !important;
                                background-color: #ffffff !important;
                                display: inline-block !important;
                            }
                            .dotted-line {
                                border-bottom: 1px dashed #000000 !important;
                                display: block !important;
                            }
                            .question-tag {
                                border: 1px dashed #000000 !important;
                                display: inline-block !important;
                            }
                        }
                    </style>
                </head>
                <body>
                    ${previewContent}
                    <script>
                        window.onload = function() {
                            window.print();
                            setTimeout(function() { window.close(); }, 500);
                        };
                    <\/script>
                </body>
                </html>
            `);
            printWindow.document.close();
        }

        function showCustomConfirm(message) {
            return new Promise((resolve) => {
                const modal = document.getElementById('custom-confirm-modal');
                const msgEl = document.getElementById('custom-confirm-message');
                const btnYes = document.getElementById('btn-confirm-yes');
                const btnNo = document.getElementById('btn-confirm-no');

                msgEl.textContent = message;
                modal.classList.add('active');

                const handleYes = () => {
                    cleanup();
                    resolve(true);
                };
                const handleNo = () => {
                    cleanup();
                    resolve(false);
                };
                const cleanup = () => {
                    btnYes.removeEventListener('click', handleYes);
                    btnNo.removeEventListener('click', handleNo);
                    modal.classList.remove('active');
                };

                btnYes.addEventListener('click', handleYes);
                btnNo.addEventListener('click', handleNo);
            });
        }

        document.getElementById('btn-exit-generator').addEventListener('click', async function () {
            if (await showCustomConfirm('Czy chcesz wrócić do strony głównej portalu?')) {
                window.location.href = 'https://www.infomatyka.pl/';
            }
        });

        (function () {
            var app = document.getElementById('app-root');
            if (app && document.body) {
                document.body.appendChild(app);
            }
            setSurvey('przed');
        })();
    </script>
</body>
</html>
